---
const links = [
  {
    label: "Email",
    href: "mailto:azijulakbar19@email.com",
    display: "azijulakbar19@email.com",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>`,
  },
  {
    label: "GitHub",
    href: "https://github.com/AzijulAkbar",
    display: "github.com/AzijulAkbar",
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/njulwelah/",
    display: "@njulwelah",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor" stroke="none"/></svg>`,
  },
];
---
<section id="contact">
  <div class="reveal">
    <p class="section-label">Kontak</p>
    <h2>Mari Berkolaborasi</h2>
    <p style="color:var(--muted);max-width:480px;margin-bottom:3rem;font-size:.95rem;line-height:1.7;">
      Tertarik bekerja sama atau punya proyek menarik? Jangan ragu untuk menghubungi saya.
    </p>
  </div>

  <div style="display:flex;flex-direction:column;gap:.75rem;" class="reveal">
    {links.map(l => (
      <a
        href={l.href}
        style="display:flex;align-items:center;gap:1.25rem;padding:1.1rem 1.5rem;background:var(--surface2);border:1px solid var(--border);border-radius:12px;transition:all .25s;group;"
        onmouseover="this.style.borderColor='rgba(167,139,250,.35)';this.style.background='rgba(124,58,237,.07)';this.style.transform='translateX(6px)'"
        onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--surface2)';this.style.transform=''"
      >
        <span style="width:36px;height:36px;border-radius:8px;background:rgba(124,58,237,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--accent-light);" set:html={l.icon}></span>
        <div>
          <p style="font-size:.7rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.1rem;">{l.label}</p>
          <p style="font-size:.9rem;color:var(--accent-light);">{l.display}</p>
        </div>
        <span style="margin-left:auto;color:var(--muted);font-size:.8rem;">→</span>
      </a>
    ))}
  </div>
</section>
