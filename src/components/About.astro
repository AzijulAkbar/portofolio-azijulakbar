---
const skills = ["PHP", "MySQL", "Laravel", "Java", "Kotlin", "Android Development", "HTML", "CSS", "JavaScript", "Blender 3D"];
---
<section id="about">
  <div class="reveal">
    <p class="section-label">Tentang Saya</p>
    <h2>Siapa saya?</h2>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:3rem;" class="reveal">
    {[
      { text: "Saya adalah siswa jurusan Rekayasa Perangkat Lunak yang fokus membangun aplikasi web dan mobile. Terbiasa menggunakan PHP, MySQL, dan Android Studio untuk membuat sistem seperti kasir, e-learning, dan pemesanan tiket." },
      { text: "Saya juga memiliki minat di bidang 3D modeling menggunakan Blender membuat aset untuk game Roblox dan eksplorasi desain visual yang membantu saya memahami sisi kreatif dalam pengembangan produk digital." },
    ].map(c => (
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:1.5rem;font-size:.9rem;color:var(--muted);line-height:1.8;">
        {c.text}
      </div>
    ))}
  </div>

  <div class="reveal">
    <p style="font-size:.75rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Tech Stack</p>
    <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
      {skills.map((skill, i) => (
        <span
          style={`background:var(--surface2);border:1px solid var(--border);padding:.35rem .9rem;border-radius:999px;font-size:.8rem;color:var(--accent-light);transition:all .2s;animation-delay:${i * 50}ms;`}
          onmouseover="this.style.borderColor='rgba(167,139,250,.4)';this.style.background='rgba(124,58,237,.1)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--surface2)'"
        >
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 600px) {
    #about div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr;
    }
  }
</style>
