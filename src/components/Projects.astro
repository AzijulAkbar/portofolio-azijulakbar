---
const projects = [
  {
    title: "Grow A Garden Roblox Assets",
    desc: "Aset 3D untuk game Roblox Grow A Garden. Berisi tanaman, pot, tanah, dan props kebun.",
    software: ["Blender", "Roblox Studio"],
    image: "/projects/AsetGAG.png",
  },
  {
    title: "Steal A Brainrot Roblox Assets",
    desc: "Aset 3D untuk game Roblox Steal A Brainrot. Berisi karakter unik, props interaktif, dan objek stylized.",
    software: ["Blender", "Roblox Studio"],
    image: "/projects/AsetSAB.png",
  },
  {
    title: "Plant vs Brainrot Roblox Assets",
    desc: "Aset 3D untuk game Roblox Plant vs Brainrot. Berisi karakter tanaman, musuh stylized, dan props arena.",
    software: ["Blender", "Roblox Studio"],
    image: "/projects/AsetPvB.png",
  },
  {
    title: "Kitchen Furniture Assets",
    desc: "Koleksi aset interior modular yang dirancang untuk kebutuhan desain interior atau visualisasi bangunan dengan tema modern-minimalis.",
    software: ["Blender"],
    image: "/projects/AsetDapur.png",
  }
];
---

<section id="projects">
  <div class="reveal">
    <p class="section-label">Portofolio</p>
    <h2>3D Modeling Projects</h2>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;" class="reveal">
    {projects.map((p, i) => (
      <button
        data-modal={i}
        style="background:var(--surface2);border:1px solid var(--border);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;text-align:left;cursor:pointer;transition:all .25s;width:100%;padding:0;"
        onmouseover="this.style.borderColor='rgba(167,139,250,.4)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 40px rgba(124,58,237,.15)'"
        onmouseout="this.style.borderColor='var(--border)';this.style.transform='';this.style.boxShadow=''"
      >
        <div style="aspect-ratio:16/9;background:#0d0d1a;overflow:hidden;">
          <img src={p.image} alt={p.title} style="width:100%;height:100%;object-fit:cover;transition:transform .4s;" onerror="this.style.display='none'" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''" />
        </div>
        <div style="padding:1.25rem;display:flex;flex-direction:column;gap:.5rem;flex:1;">
          <h3 style="font-size:1rem;color:#fff;font-weight:600;">{p.title}</h3>
          <p style="color:var(--muted);font-size:.825rem;flex:1;line-height:1.6;">{p.desc}</p>
          <div style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.5rem;">
            {p.software.map(s => (
              <span style="font-size:.7rem;color:var(--accent-light);background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);padding:.2rem .6rem;border-radius:4px;">{s}</span>
            ))}
          </div>
        </div>
      </button>
    ))}
  </div>
</section>

<!-- Modal data di-inject via JS agar selalu center di viewport -->
<div id="modal-overlay" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,0.85);backdrop-filter:blur(12px);align-items:center;justify-content:center;">
  <div id="modal-box" style="background:var(--surface2);border:1px solid var(--border);border-radius:16px;width:90%;max-width:560px;max-height:90vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.6);">
    <img id="modal-img" src="" alt="" style="width:100%;aspect-ratio:16/9;object-fit:cover;display:block;flex-shrink:0;" />
    <div style="padding:1.5rem;display:flex;flex-direction:column;gap:1rem;overflow-y:auto;flex:1;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;">
        <h3 id="modal-title" style="font-size:1.15rem;color:#fff;font-weight:600;"></h3>
      </div>
      <div id="modal-software" style="display:flex;flex-wrap:wrap;gap:.4rem;"></div>
      <p id="modal-details" style="color:var(--muted);font-size:.875rem;white-space:pre-line;line-height:1.8;"></p>
    </div>
    <div id="modal-footer" style="display:flex;gap:.75rem;padding:1rem 1.5rem;border-top:1px solid var(--border);flex-shrink:0;"></div>
  </div>
</div>

<script>
  const data = [
    ...document.querySelectorAll('[data-modal]')
  ].map(btn => {
    const i = btn.getAttribute('data-modal');
    return {
      i,
      title: btn.querySelector('h3')!.textContent!,
      desc: btn.querySelector('p')!.textContent!,
      image: btn.querySelector('img')!.src,
      software: [...btn.querySelectorAll('span')].map(s => s.textContent!),
    };
  });

  const overlay = document.getElementById('modal-overlay')!;
  const box = document.getElementById('modal-box')!;
  const imgEl = document.getElementById('modal-img') as HTMLImageElement;
  const titleEl = document.getElementById('modal-title')!;
  const softwareEl = document.getElementById('modal-software')!;
  const detailsEl = document.getElementById('modal-details')!;

  const scrollEl = document.querySelector('#modal-box > div') as HTMLElement;
  const footerEl = document.getElementById('modal-footer')!;

  function closeModal() {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
    requestAnimationFrame(() => { scrollEl.scrollTop = 0; });
  }

  window.addEventListener('popstate', () => {
    if (overlay.style.display === 'flex') closeModal();
  });

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  const links = [
    {
      install: { mediafire: 'https://www.mediafire.com/file/d67skx7iw7gso44/GrowAGarden.rar/file', savelink: 'https://sfl.gl/ViuAuv' }
    },
    {
      install: { mediafire: 'https://www.mediafire.com/file/q268bjl9brvp3k3/StealABerainrot.rar/file', savelink: 'https://sfl.gl/mTOQfD' }
    },
    {
      install: { mediafire: 'https://www.mediafire.com/file/yfqjeq1cqhsyezm/PlantVsBrainrot.rar/file', savelink: 'https://sfl.gl/FwvfXRV' }
    },
    {
      install: { mediafire: 'https://www.mediafire.com/file/x1v45kpzyx2ejth/Kitchen_Furniture.rar/file', savelink: 'https://sfl.gl/G4POq' }
    },
  ];

  const details = [
    `Grow a Garden adalah game indie di platform Roblox yang dikembangkan oleh Splitting Point Studios dan Do Big Studios.

    Penjelasan Game: Game ini berfokus pada simulasi berkebun di mana pemain mengelola lahan untuk menumbuhkan berbagai jenis tanaman.
    
    Cara Bermain:
    1. Pemain memulai dengan sebidang tanah kecil untuk menanam bunga, buah-buahan, dan sayuran.
    2. Setelah tanaman tumbuh, pemain dapat memanen dan menjual hasilnya untuk mendapatkan mata uang bernama Sheckles.
    3. Sheckles tersebut kemudian digunakan untuk membeli benih baru, peralatan (gears), telur (eggs), serta barang dekoratif.
    
    Fitur Utama:
    1. Peningkatan Pengalaman: Pemain bisa memperluas lahan dan menggunakan gears untuk mempercepat proses pertumbuhan.
    2. Sistem Pet: Pemain dapat menetaskan telur untuk mendapatkan hewan peliharaan (pets) yang memiliki kemampuan pasif unik untuk membantu pertumbuhan tanaman.
    3. Cuaca dan Mutasi: Adanya sistem cuaca dapat memicu mutasi tanaman, yang meningkatkan nilai jual hasil panen atau membantu menyelesaikan misi (quests) tertentu.
    4. Event: Terdapat event musiman seperti Easter 2026 dan fitur komunitas seperti Community Garden.`,

    `Steal a Brainrot adalah game Roblox karya pengembang BRAZILIAN SPYDER dan Sammy.

    Penjelasan Game: Berbeda dengan dua game sebelumnya, game ini memiliki aspek kompetitif yang kuat di mana pemain saling berinteraksi secara agresif.
    
    Cara Bermain:
    1. Tujuan utama pemain adalah mencuri Brainrots milik pemain lain.
    2. Dengan mencuri, pemain akan mendapatkan lebih banyak uang yang bisa digunakan untuk membeli lebih banyak Brainrots untuk koleksi mereka sendiri.
    3. Sambil menyerang, pemain juga harus mempertahankan Brainrots milik mereka sendiri agar tidak dicuri balik oleh orang lain.
    
    Fitur Utama:
    1. Lucky Blocks: Pemain bisa berinteraksi dengan berbagai jenis blok keberuntungan seperti Admin Lucky Block atau Mythic Lucky Block.
    2. Perdagangan: Tersedia fitur Trade Machine yang memungkinkan pemain bertukar koleksi secara aman.
    3. Kustomisasi dan Evolusi: Terdapat fitur mutasi, mesin pelebur (fuse machine), dan sistem traits untuk memperkuat koleksi.
    4. Event Rutin: Game ini memiliki jadwal event khusus seperti Taco Tuesday yang diadakan setiap hari Selasa.`,

    `Plants & Brainrots adalah game Roblox yang dikembangkan oleh Splitting Point - PVB.

    Penjelasan Game: Fokus utama game ini adalah pertarungan antara tanaman dan makhluk yang disebut brainrots.
    
    Cara Bermain:
    1. Pemain harus menanam berbagai jenis tanaman yang berfungsi untuk menghancurkan serangan brainrots.
    2. Setiap kali berhasil menghancurkan musuh, pemain akan mendapatkan uang.
    3. Uang ini digunakan untuk membeli tanaman yang lebih kuat dan berbagai peningkatan (upgrades) lainnya.
    
    Fitur Utama:
    1. Elemen Gameplay: Game ini menyediakan fitur Lucky Eggs, peralatan (gears), kartu (cards), dan sistem mutasi.
    2. Eksplorasi: Terdapat berbagai biome, sistem cuaca, dan alur cerita (story) yang bisa diikuti pemain.
    3. Mekanik Lanjutan: Pemain dapat menggunakan mesin pelebur (Fuse Machine) dan melakukan Rebirth untuk kemajuan karakter yang lebih jauh.`,

    `Aset Furniture Dapur Modern Aset Furniture Dapur adalah rangkaian model interior modular yang dirancang untuk kebutuhan visualisasi arsitektur dan desain ruangan.

    Penjelasan Aset: Koleksi ini mengusung tema minimalis-modern dengan sentuhan tekstur kayu berwarna cokelat tua dan aksen abu-abu industrial pada unit penyimpanan utama. Desainnya yang bersih dan fungsional membuatnya cocok untuk berbagai konsep hunian kontemporer.
    
    Cara Penggunaan:
    1. Desainer dapat menyusun tata letak (layout) sesuai dengan dimensi ruangan yang tersedia karena setiap unit furnitur bersifat terpisah atau modular.
    2. Aset ini digunakan untuk mengisi ruang dapur dalam maket digital atau render interior guna memberikan gambaran estetika dan sirkulasi ruang bagi penghuni.
    3. Penempatan komponen seperti kabinet gantung dan meja counter dapat disesuaikan untuk menciptakan dapur bertipe L-shape, U-shape, maupun linear.
    
    Detail Fitur:
    1. Modul Wastafel: Kabinet bawah dengan detail profil pintu klasik, dilengkapi wastafel logam ganda dan keran high-neck modern.
    2. Unit Pantry Tall-Cabinet: Lemari penyimpanan tinggi berpintu ganda berwarna abu-abu yang kontras, ideal untuk menyimpan perlengkapan dapur besar atau bahan makanan.
    3. Kabinet Dinding Modular: Lemari gantung yang tersedia dalam modul tunggal maupun rangkaian sudut untuk memaksimalkan penyimpanan vertikal.
    4. Meja Counter Luas: Permukaan meja kerja yang lebar dengan desain minimalis tanpa pegangan (handleless look), memberikan kesan ruang yang rapi dan elegan.
    `,
  ];

  function openModal(i: number) {
    const d = data[i];
    imgEl.src = d.image;
    imgEl.alt = d.title;
    titleEl.textContent = d.title;
    detailsEl.textContent = details[i];
    softwareEl.innerHTML = d.software.map(s =>
      `<span style="font-size:.75rem;color:var(--accent-light);background:#1f1535;padding:.2rem .6rem;border-radius:4px;">${s}</span>`
    ).join('');
    footerEl.innerHTML = `
      <div style="position:relative;flex:1;">
        <button onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='flex'?'none':'flex'" style="width:100%;padding:.6rem;border-radius:6px;border:1px solid #404040;color:var(--muted);font-size:.875rem;background:none;cursor:pointer;">⬇ Install Aset</button>
        <div style="display:none;position:absolute;bottom:110%;left:0;width:100%;background:#1a1a1a;border:1px solid #2e2e2e;border-radius:6px;flex-direction:column;overflow:hidden;z-index:10;">
          <a href="${links[i].install.mediafire}" target="_blank" style="padding:.6rem 1rem;font-size:.875rem;color:var(--text);display:block;" onmouseover="this.style.background='#262626'" onmouseout="this.style.background=''">Mediafire</a>
          <a href="${links[i].install.savelink}" target="_blank" style="padding:.6rem 1rem;font-size:.875rem;color:var(--text);display:block;border-top:1px solid #2e2e2e;" onmouseover="this.style.background='#262626'" onmouseout="this.style.background=''">Savelink</a>
        </div>
      </div>
    `
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    history.pushState({ modal: true }, '');
    requestAnimationFrame(() => { scrollEl.scrollTop = 0; });
  }

  document.querySelectorAll('[data-modal]').forEach(btn => {
    btn.addEventListener('click', () => {
      openModal(Number(btn.getAttribute('data-modal')));
    });
  });
</script>
