---
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
}
const { title = "Azijul Akbar — Portfolio" } = Astro.props;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #0f0f0f;
        --surface: #1a1a1a;
        --accent: #7c3aed;
        --accent-light: #a78bfa;
        --text: #e5e5e5;
        --muted: #737373;
      }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, sans-serif;
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      section { padding: 5rem 1.5rem; max-width: 900px; margin: 0 auto; }
      h2 { font-size: 1.75rem; margin-bottom: 2rem; color: #ffffff; }
    </style>
  </head>
  <body>
    <nav style="position:sticky;top:0;z-index:10;background:var(--bg);border-bottom:1px solid #262626;padding:.75rem 1.5rem;display:flex;justify-content:space-between;align-items:center;">
      <span style="font-weight:700;color:var(--accent-light);">Azijul Akbar</span>
      <div style="display:flex;gap:1.5rem;font-size:.9rem;color:var(--muted);">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>

    <slot />

    <footer style="text-align:center;padding:2rem;color:var(--muted);font-size:.85rem;border-top:1px solid #262626;">
      Copyright © {new Date().getFullYear()} 2026 Azijul Akbar Nur Fatihah
    </footer>
    <Analytics />
  </body>
</html>
